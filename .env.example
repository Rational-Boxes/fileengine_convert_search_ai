# convert_search_ai configuration — copy to .env and fill in. .env is gitignored.
# FILEENGINE_* names are shared with the core / bridges / mcp; CSAI_* are service-specific.

# --- gRPC core ---
FILEENGINE_GRPC_HOST=localhost
FILEENGINE_GRPC_PORT=50051

# --- This service's agent identity (indexing / rendition writes only) ---
FILEENGINE_CSAI_USER=
FILEENGINE_CSAI_PASSWORD=
FILEENGINE_CSAI_TENANT=default

# --- Auth coordination with the core REST API (http_bridge) ---
# Set to the bridge's base URL to accept bridge-issued bearer tokens here too
# (validated via the bridge's /v1/auth/introspect), so one login — LDAP OR OAuth,
# at the bridge — authenticates across both services. Empty disables it (this
# service then accepts only its own /auth/token tokens + Basic auth).
#
# REQUIRED if the Vue SPA / frontend uses chat or search here: the SPA does NOT
# log in separately — it reuses the bridge token it already holds, so leaving
# this empty makes chat fail with "authentication required" (the WS closes 4401).
# Local stack: http://localhost:8090 ; in Docker the compose sets it to the
# in-network bridge (http://http-bridge:8090).
CSAI_BRIDGE_URL=
CSAI_BRIDGE_INTROSPECT_TTL=60   # seconds to cache an introspection result
# Browser CORS: comma-separated origins allowed to call this service from a
# SPA on another origin (e.g. the frontend dev server). Empty = disabled.
CSAI_CORS_ORIGINS=

# --- LDAP (auth/role authority) ---
FILEENGINE_LDAP_ENDPOINT=ldap://localhost:1389
FILEENGINE_LDAP_DOMAIN=dc=rationalboxes,dc=com
FILEENGINE_LDAP_USER_BASE=ou=users,dc=rationalboxes,dc=com
FILEENGINE_LDAP_TENANT_BASE=ou=tenants,dc=rationalboxes,dc=com
FILEENGINE_LDAP_BIND_DN=cn=admin,dc=rationalboxes,dc=com
FILEENGINE_LDAP_BIND_PASSWORD=admin

# --- This service's own Postgres (needs the pgvector extension; dev runs on 5434) ---
CSAI_PG_HOST=localhost
CSAI_PG_PORT=5434
CSAI_PG_DATABASE=convert_search_ai
CSAI_PG_USER=fileengine_user
CSAI_PG_PASSWORD=fileengine_password

# --- Event ingestion (consumes the core publisher's Redis stream) ---
FILEENGINE_REDIS_HOST=localhost
FILEENGINE_REDIS_PORT=6379
FILEENGINE_REDIS_PASSWORD=
FILEENGINE_EVENTS_STREAM=fileengine:events
CSAI_EVENTS_GROUP=convert_search_ai

# --- HTTP / WebSocket surface ---
CSAI_HTTP_HOST=127.0.0.1
CSAI_HTTP_PORT=8092

# --- Permission cache (<= 5 min per spec; also invalidated in real time by the
#     acl.changed / role.* events from the core publisher) ---
CSAI_PERMISSION_CACHE_TTL=300

# --- Bearer-token TTL for POST /auth/token ---
CSAI_TOKEN_TTL=3600

# --- Guardrails (caps; 0 = unlimited) + audit ---
CSAI_MAX_QUERY_CHARS=1000
CSAI_MAX_RESULTS=100
CSAI_MAX_CHAT_K=12
CSAI_MAX_CONTEXT_CHARS=12000
CSAI_MAX_TEXT_BYTES=5242880
CSAI_DB_STATEMENT_TIMEOUT_MS=5000
CSAI_AUDIT_LOG_FILE=          # empty -> stderr

# --- PDF/Office -> Markdown extraction backends (fidelity-ordered; first installed wins) ---
# docling (best structure+tables, MIT, heavy) > pymupdf4llm (great, PyMuPDF is AGPL) >
# pdfplumber (solid tables, MIT, light) > pdftotext (plain text, last resort).
CSAI_PDF_BACKENDS=docling,pymupdf4llm,pdfplumber,pdftotext

# --- Document page-1 preview sizes (longest edge, px) ---
# For PDF + Office documents: an icon-sized thumbnail and a larger first-page
# preview (PNG, via poppler). Office docs also get an inline 'pdf' rendition.
CSAI_DOC_THUMBNAIL_PX=256
CSAI_DOC_PREVIEW_PX=1280

# --- Pluggable AI providers (choose at deploy time; DEVELOPMENT_PLAN §7) ---
# The embedder and the chat LLM are configured INDEPENDENTLY (separate provider,
# model, endpoint, and key). This is deliberate: lightweight embedding can run
# locally on CPU (e.g. a bundled Ollama) while interactive chat targets an
# external heavy-compute service. At startup the resolved pair is logged
# ("AI providers — embeddings: … | chat: …") so you can confirm the split.
# Embeddings: hash (offline default) | voyage | openai | ollama | openai-compatible
CSAI_EMBEDDING_PROVIDER=
CSAI_EMBEDDING_MODEL=
CSAI_EMBEDDING_DIMENSION=1024          # MUST match the model's output dim (pgvector column)
CSAI_EMBEDDING_BASE_URL=               # OpenAI-compatible base URL (ollama sets one by default)
CSAI_EMBEDDING_API_KEY=                # falls back to OPENAI_API_KEY
CSAI_EMBEDDING_SEND_DIMENSIONS=false   # only OpenAI-native models accept the `dimensions` param
# Chat: anthropic (default) | openai | ollama | openai-compatible | echo
CSAI_CHAT_PROVIDER=anthropic
CSAI_CHAT_MODEL=claude-sonnet-4-6
CSAI_CHAT_BASE_URL=                     # OpenAI-compatible base URL (ollama sets one by default)
CSAI_CHAT_API_KEY=                      # falls back to OPENAI_API_KEY
CSAI_CHAT_MAX_TOKENS=8192               # max output tokens; keep generous — the create_document
                                        # tool emits the whole HTML report as a tool-call argument
                                        # and a small cap truncates it (report fails to save)
#
# Examples:
#   OpenAI chat:  CSAI_CHAT_PROVIDER=openai CSAI_CHAT_MODEL=gpt-4o-mini CSAI_CHAT_API_KEY=sk-...
#   Local Ollama: CSAI_CHAT_PROVIDER=ollama CSAI_CHAT_MODEL=llama3.2
#                 CSAI_EMBEDDING_PROVIDER=ollama CSAI_EMBEDDING_MODEL=mxbai-embed-large
#                 CSAI_EMBEDDING_DIMENSION=1024   (mxbai-embed-large is 1024-dim)
#   Split (unified-stack default) — CPU-local embeddings, external chat:
#                 CSAI_EMBEDDING_PROVIDER=ollama CSAI_EMBEDDING_MODEL=nomic-embed-text
#                 CSAI_EMBEDDING_BASE_URL=http://ollama:11434/v1 CSAI_EMBEDDING_DIMENSION=768
#                 CSAI_CHAT_PROVIDER=anthropic CSAI_CHAT_MODEL=claude-sonnet-4-6 ANTHROPIC_API_KEY=sk-ant-...
# Provider API keys (only what the chosen providers need):
# ANTHROPIC_API_KEY=
# VOYAGE_API_KEY=
# OPENAI_API_KEY=

# --- Web search tool (chat-with-documents) — OFF by default ----------------
# Lets the chat model search the internet. A search sends the query to a third
# party, so it is disabled until you opt in. Backend defaults to DuckDuckGo
# (no API key; `pip install .[websearch]`). Tool-loop wiring lands in P2.
CSAI_WEB_SEARCH_ENABLED=false           # master switch
CSAI_WEB_SEARCH_PROVIDER=duckduckgo     # duckduckgo | fake | none
CSAI_WEB_SEARCH_DEFAULT=false           # default when a client omits the flag
CSAI_WEB_SEARCH_RESULTS=5               # results per search
CSAI_TOOL_MAX_ITERATIONS=8              # tool-loop cap per answer — governs ALL tools
                                        # (web_search + list_folders + create_document); keep
                                        # high enough that explore-then-save report flows finish.
                                        # (legacy alias: CSAI_WEB_MAX_ITERATIONS)
CSAI_WEB_MAX_CHARS=4000                 # web text into the shared context budget
CSAI_WEB_TIMEOUT_MS=4000                # per-search wall-clock
CSAI_WEB_REGION=wt-wt                   # DuckDuckGo region
CSAI_WEB_SAFESEARCH=moderate            # off | moderate | strict
CSAI_WEB_TIMELIMIT=                     # "" | d | w | m | y
# Optional fetch_page tool: read a result's full page text (SSRF-guarded, https
# only, public hosts only). Off by default; only active when web search is on.
CSAI_WEB_FETCH_PAGES=false
CSAI_WEB_FETCH_MAX_BYTES=2097152        # 2 MiB read cap per page

# --- create_document chat tool ------------------------------------------------
# Lets chat save a report generated from the conversation as an HTML document in
# the user's own storage (written AS the user, so ACLs apply), with an automatic
# PDF preview. The model confirms the destination folder/name with the user
# first. On by default (needs a tool-capable chat provider).
CSAI_CHAT_DOCUMENT_TOOL=true
CSAI_CHAT_DOCUMENT_MAX_BYTES=5242880    # 5 MiB cap on a generated report

# --- HTML → PDF conversion ----------------------------------------------------
# Renders .html documents (incl. chat-generated reports) to a full-document PDF
# + page previews. Chromium headless gives full-CSS fidelity; LibreOffice is the
# fallback. Point CSAI_HTML_CHROMIUM at your Chromium/Chrome binary if needed.
CSAI_HTML_CHROMIUM=chromium-browser
CSAI_HTML_PDF_TIMEOUT_S=60
