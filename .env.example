# convert_search_ai configuration — copy to .env and fill in. .env is gitignored.
# FILEENGINE_* names are shared with the core / bridges / mcp; CSAI_* are service-specific.

# --- gRPC core ---
FILEENGINE_GRPC_HOST=localhost
FILEENGINE_GRPC_PORT=50051

# --- This service's agent identity (indexing / rendition writes only) ---
FILEENGINE_CSAI_USER=
FILEENGINE_CSAI_PASSWORD=
FILEENGINE_CSAI_TENANT=default

# --- LDAP (auth/role authority) ---
FILEENGINE_LDAP_ENDPOINT=ldap://localhost:1389
FILEENGINE_LDAP_DOMAIN=dc=rationalboxes,dc=com
FILEENGINE_LDAP_USER_BASE=ou=users,dc=rationalboxes,dc=com
FILEENGINE_LDAP_TENANT_BASE=ou=tenants,dc=rationalboxes,dc=com
FILEENGINE_LDAP_BIND_DN=cn=admin,dc=rationalboxes,dc=com
FILEENGINE_LDAP_BIND_PASSWORD=admin

# --- This service's own Postgres (needs the pgvector extension; dev runs on 5434) ---
CSAI_PG_HOST=localhost
CSAI_PG_PORT=5434
CSAI_PG_DATABASE=convert_search_ai
CSAI_PG_USER=fileengine_user
CSAI_PG_PASSWORD=fileengine_password

# --- Event ingestion (consumes the core publisher's Redis stream) ---
FILEENGINE_REDIS_HOST=localhost
FILEENGINE_REDIS_PORT=6379
FILEENGINE_REDIS_PASSWORD=
FILEENGINE_EVENTS_STREAM=fileengine:events
CSAI_EVENTS_GROUP=convert_search_ai

# --- HTTP / WebSocket surface ---
CSAI_HTTP_HOST=127.0.0.1
CSAI_HTTP_PORT=8092

# --- Permission cache (<= 5 min per spec; also invalidated in real time by the
#     acl.changed / role.* events from the core publisher) ---
CSAI_PERMISSION_CACHE_TTL=300

# --- Bearer-token TTL for POST /auth/token ---
CSAI_TOKEN_TTL=3600

# --- Guardrails (caps; 0 = unlimited) + audit ---
CSAI_MAX_QUERY_CHARS=1000
CSAI_MAX_RESULTS=100
CSAI_MAX_CHAT_K=12
CSAI_MAX_CONTEXT_CHARS=12000
CSAI_MAX_TEXT_BYTES=5242880
CSAI_DB_STATEMENT_TIMEOUT_MS=5000
CSAI_AUDIT_LOG_FILE=          # empty -> stderr

# --- PDF/Office -> Markdown extraction backends (fidelity-ordered; first installed wins) ---
# docling (best structure+tables, MIT, heavy) > pymupdf4llm (great, PyMuPDF is AGPL) >
# pdfplumber (solid tables, MIT, light) > pdftotext (plain text, last resort).
CSAI_PDF_BACKENDS=docling,pymupdf4llm,pdfplumber,pdftotext

# --- Pluggable AI providers (choose at deploy time; DEVELOPMENT_PLAN §7) ---
CSAI_EMBEDDING_PROVIDER=
CSAI_EMBEDDING_MODEL=
CSAI_EMBEDDING_DIMENSION=1024
CSAI_CHAT_PROVIDER=anthropic
CSAI_CHAT_MODEL=claude-sonnet-4-6
# Provider API keys (only what the chosen providers need):
# ANTHROPIC_API_KEY=
# VOYAGE_API_KEY=
# OPENAI_API_KEY=
